# Soularr config template. Deployed to /opt/jellystack/appdata/soularr/config.ini
# with __LIDARR_API_KEY__ / __SLSKD_API_KEY__ replaced from jellystack.env
# (see jellystack.md "Deploy the music services").
#
# download_dir paths: slskd writes completed transfers to its /downloads/complete,
# which is /opt/jellystack/media/downloads/slskd/complete on the CT. Both Soularr
# and Lidarr mount media/downloads at /downloads, so they see the same files at
# /downloads/slskd/complete.
[Lidarr]
api_key = __LIDARR_API_KEY__
host_url = http://lidarr:8686
download_dir = /downloads/slskd/complete

[Slskd]
api_key = __SLSKD_API_KEY__
host_url = http://gluetun:5030
url_base = /
download_dir = /downloads/slskd/complete
delete_searches = False
stalled_timeout = 3600

[Release Settings]
use_most_common_tracknum = True
allow_multi_disc = True
accepted_countries = Europe,Japan,United Kingdom,United States,[Worldwide],Australia,Canada,New Zealand
accepted_formats = CD,Digital Media,Vinyl

[Search Settings]
search_timeout = 5000
maximum_peer_queue = 50
minimum_peer_upload_speed = 0
minimum_filename_match_ratio = 0.8
allowed_filetypes = flac 24/192,flac 16/44.1,flac,mp3 320,mp3
ignored_users =
search_for_tracks = True
album_prepend_artist = False
track_prepend_artist = True
search_type = incrementing_page
number_of_albums_to_grab = 10
remove_wanted_on_failure = False

[Logging]
level = INFO
format = [%(levelname)s|%(module)s|L%(lineno)d] %(asctime)s: %(message)s
datefmt = %Y-%m-%dT%H:%M:%S%z

[Lidarr Settings]
disable_sync = False
