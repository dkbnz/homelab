{
  "title": "Homelab Overview",
  "uid": "homelab-overview",
  "tags": ["homelab"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-12h", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "Host CPU",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "100 - avg(rate(node_cpu_seconds_total{node=\"proxmox\",mode=\"idle\"}[5m])) * 100", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] } }, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "Host temp",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "max(node_hwmon_temp_celsius{node=\"proxmox\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "celsius", "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 90 }] } }, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "Host memory",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "(1 - node_memory_MemAvailable_bytes{node=\"proxmox\"} / node_memory_MemTotal_bytes{node=\"proxmox\"}) * 100", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 92 }] } }, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "Scrape targets up",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "count(up == 1)", "refId": "A" }, { "expr": "count(up)", "refId": "B" }],
      "fieldConfig": { "defaults": { "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "Containers running (CT102)",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "count(container_start_time_seconds{name=~\".+\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "Guests up (PVE)",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(pve_up{id=~\"qemu/100|lxc/101|lxc/102\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 2 }, { "color": "green", "value": 3 }] } }, "overrides": [] }
    },
    {
      "type": "bargauge",
      "title": "Disk usage",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "100 - node_filesystem_avail_bytes{node=\"proxmox\",mountpoint=\"/\"} / node_filesystem_size_bytes{node=\"proxmox\",mountpoint=\"/\"} * 100", "legendFormat": "root (/)", "refId": "A", "instant": true },
        { "expr": "100 - node_filesystem_avail_bytes{node=\"proxmox\",mountpoint=\"/mnt/t7\"} / node_filesystem_size_bytes{node=\"proxmox\",mountpoint=\"/mnt/t7\"} * 100", "legendFormat": "T7", "refId": "B", "instant": true },
        { "expr": "100 - node_filesystem_avail_bytes{node=\"proxmox\",mountpoint=\"/mnt/sdc\"} / node_filesystem_size_bytes{node=\"proxmox\",mountpoint=\"/mnt/sdc\"} * 100", "legendFormat": "sdc (backup)", "refId": "C", "instant": true },
        { "expr": "pve_disk_usage_bytes{id=~\"storage/.*/local-lvm\"} / pve_disk_size_bytes{id=~\"storage/.*/local-lvm\"} * 100", "legendFormat": "local-lvm", "refId": "D", "instant": true }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 80 }, { "color": "red", "value": 92 }] } }, "overrides": [] },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "timeseries",
      "title": "Host CPU + temp",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "100 - avg(rate(node_cpu_seconds_total{node=\"proxmox\",mode=\"idle\"}[5m])) * 100", "legendFormat": "cpu %", "refId": "A" },
        { "expr": "max(node_hwmon_temp_celsius{node=\"proxmox\"})", "legendFormat": "temp °C", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "min": 0 }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Guest memory (PVE)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "pve_memory_usage_bytes{id=~\"qemu/100|lxc/101|lxc/102\"} / pve_memory_size_bytes * 100", "legendFormat": "{{id}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Starlink throughput (via Home Assistant)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "{__name__=~\"hass_sensor_.*\", entity=~\"sensor.starlink_(downlink|uplink)_throughput\"}", "legendFormat": "{{entity}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "min": 0 }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Container CPU (top 10)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "topk(10, rate(container_cpu_usage_seconds_total{name=~\".+\"}[5m]) * 100)", "legendFormat": "{{name}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0 }, "overrides": [] }
    }
  ]
}
