{
  "title": "Minecraft",
  "uid": "homelab-minecraft",
  "tags": ["homelab", "minecraft"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "type": "stat",
      "title": "Server up",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "up{job=\"minecraft\"}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Players online",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "sum(minecraft_player_online) or vector(0)", "refId": "A" }],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "Overworld TPS",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "minecraft_dimension_tps{dimension=\"overworld\"}", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 15 }, { "color": "green", "value": 19 }] }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Container memory",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "container_memory_working_set_bytes{name=\"minecraft\"}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "bytes", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3221225472 }] } }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "TPS by dimension",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "minecraft_dimension_tps", "legendFormat": "{{dimension}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "min": 0, "max": 20, "decimals": 1 }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Tick time by dimension (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "minecraft_dimension_ticktime_ms", "legendFormat": "{{dimension}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "ms", "min": 0 }, "overrides": [] }
    },
    {
      "type": "bargauge",
      "title": "Play time (hours)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "minecraft_play_time_ticks_total / 20 / 3600", "legendFormat": "{{player}}", "refId": "A", "instant": true }],
      "fieldConfig": { "defaults": { "unit": "h", "decimals": 1, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }, "overrides": [] },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "bargauge",
      "title": "Deaths",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "minecraft_deaths_total", "legendFormat": "{{player}}", "refId": "A", "instant": true }],
      "fieldConfig": { "defaults": { "decimals": 0, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] } }, "overrides": [] },
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } }
    }
  ]
}
