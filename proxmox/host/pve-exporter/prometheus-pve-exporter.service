[Unit]
Description=Prometheus Proxmox VE exporter (per-VM/CT + storage metrics)
After=network-online.target
Wants=network-online.target

[Service]
User=pve_exporter
Group=pve_exporter
ExecStart=/opt/pve-exporter/bin/pve_exporter \
    --config.file /etc/prometheus/pve.yml \
    --web.listen-address :9221
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
